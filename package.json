{
  "name": "booking-marketplace-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter @booking-marketplace/backend start:dev",
    "dev:frontend": "pnpm --filter @booking-marketplace/frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @booking-marketplace/backend test",
    "test:e2e": "pnpm --filter @booking-marketplace/backend test:e2e"
  }
}